diff:1251799685:1251799552:=24,31c24%0a%3c %0a%3c ! Running Dspam via .qmail-default%0a%3c # /domains/%3cdomain>/.qmail-spam%0a%3c  |/usr/bin/dspam --user $EXT@$USER --class=spam --source=error%0a%3c #./domains/%3cdomain>/.qmail-innocent (untested, as I've not seen any false positives yet)%0a%3c  |/usr/bin/dspam --user $EXT@$USER --class=innocent --source=error%0a%3c # By modifying the .qmail-default configuration file:%0a%3c  | /usr/bin/dspam --deliver=innocent --user $EXT@$USER  --stdout | /var/%0a\ No newline at end of file%0a---%0a> *%0a\ No newline at end of file%0a
