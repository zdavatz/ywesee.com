diff:1152707347:1152707327:=55,56c55%0a%3c # mount -o bind /proc /mnt/gentoo/proc%0a%3c # lilo -x mbr%0a\ No newline at end of file%0a---%0a> # mount -o bind /proc /mnt/gentoo/proc%0a\ No newline at end of file%0a
host:1152707347=84.72.154.185
author:1152707327=
diff:1152707327:1152707165:=51,55c51%0a%3c # mdadm --assemble --run /dev/md0 /dev/hda1%0a%3c # mount /dev/md1 /mnt/gentoo%0a%3c # mount /dev/md0 /mnt/gentoo/boot%0a%3c # mount -o bind /dev /mnt/gentoo/dev%0a%3c # mount -o bind /proc /mnt/gentoo/proc%0a\ No newline at end of file%0a---%0a> # mdadm --assemble --run /dev/md0 /dev/hda1%0a\ No newline at end of file%0a
host:1152707327=84.72.154.185
author:1152707165=
diff:1152707165:1120748935:=45,51c45%0a%3c * > umount /mnt%0a%3c %0a%3c !!!When having Lilo problems%0a%3c # boot from CD%0a%3c # mknod /dev/md0 b 9 0%0a%3c # mknod /dev/md1 b 9 1%0a%3c # mdadm --assemble --run /dev/md0 /dev/hda1%0a\ No newline at end of file%0a---%0a> * > umount /mnt%0a\ No newline at end of file%0a
host:1152707165=84.72.154.185
