diff:1212041964:1152708160:=35,36c35%0a%3c * echo 50000 >/proc/sys/dev/raid/speed_limit_min%0a%3c %0a---%0a> %0a
host:1212041964=77.57.16.157
author:1152708160=
diff:1152708160:1152707347:=52d51%0a%3c # mdadm -a /dev/md0 /dev/hdc1%0a
