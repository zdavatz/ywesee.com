diff:1231334674:1231334131:=61,62c61%0a%3c #  mdadm --grow /dev/md1 --size=max - also see http://www.silfreed.net/content/argo-hard-drive-upgrade-growing-raid1-array%0a%3c # Resizing with JFS: # mount -o remount,resize /mount/point - also see http://www.linux.com/articles/32002%0a\ No newline at end of file%0a---%0a> #  mdadm --grow /dev/md1 --size=max - also see http://www.silfreed.net/content/argo-hard-drive-upgrade-growing-raid1-array%0a\ No newline at end of file%0a
host:1231334674=84.72.92.25
author:1231334131=
diff:1231334131:1212041964:=58,61c58%0a%3c # lilo -x mbr%0a%3c %0a%3c !!!Growing a Software Raid1%0a%3c #  mdadm --grow /dev/md1 --size=max - also see http://www.silfreed.net/content/argo-hard-drive-upgrade-growing-raid1-array%0a\ No newline at end of file%0a---%0a> # lilo -x mbr%0a\ No newline at end of file%0a
host:1231334131=84.72.92.25
